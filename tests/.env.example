# --- LLM (офлайн-тесты в tests/<модуль>/) ---
SBER_AUTH=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
LLM_MODEL=GigaChat
LLM_GENERATION_MODEL=GigaChat

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=AI-Lawyer

HASH_LENGTH=8
GENERATED_DOCX_PATH=/generated_docx

LOGS_DIR=
LOGS_FILE=inference_server.log
MODE=DEBUG

REDIS_URL=redis://localhost:6379

# --- Smoke-тесты inference-server (tests/api_smoke/run.py) ---
INFERENCE_BASE_URL=http://localhost:8000
INFERENCE_API_PREFIX=/api/chat
SMOKE_HTTP_TIMEOUT=600
