SBER_AUTH=
# Версия API GigaChat — должна совпадать с типом ключа в личном кабинете Сбера:
# GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_B2B
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=AI-Lawyer

HASH_LENGTH=8
GENERATED_DOCX_PATH=/generated_docx

LLM_MODEL=GigaChat
LLM_GENERATION_MODEL=GigaChat

LOGS_DIR=/logs
LOGS_FILE=inference_server.log

MODE=DEBUG

REDIS_URL=redis://redis:6379
